rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Admin membership comes from Firestore document existence:
      // /admins/{uid}
      return signedIn() &&
          exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // User profile images
    match /profiles/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    // XR panorama/media content
    match /tours/{tourId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
